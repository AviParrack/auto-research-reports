---
import '../styles/global.css';
import type { Report } from '../lib/reports';
import { BUILD_HASH } from '../lib/build-hash';
import { SITE_VERSION, SITE_STAGE } from '../lib/version';
import { buildTooltipPayload } from '../lib/reports';

interface Props {
  report: Report;
  title: string;
  activeTab?: 'report' | 'analysis' | 'sources' | 'glossary' | 'log';
}

const { report, title, activeTab = 'report' } = Astro.props;
const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';

function fmtTs(v: unknown): string {
  if (v instanceof Date) return v.toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
  if (typeof v === 'string') return v.replace('T', ' ').replace(/Z$/, ' UTC').replace(/\.\d+/, '');
  return String(v);
}
const reportUpdatedStr = fmtTs(report.meta.last_updated);
const tooltipPayload = buildTooltipPayload(report);

const tabs = [
  { id: 'report', label: 'Report', href: `/${report.slug}/` },
  { id: 'analysis', label: 'Analysis', href: `/${report.slug}/analysis/` },
  { id: 'sources', label: 'Sources', href: `/${report.slug}/sources/` },
  { id: 'glossary', label: 'Glossary', href: `/${report.slug}/glossary/` },
  { id: 'log', label: 'Pass Log', href: `/${report.slug}/log/` },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="build-hash" content={BUILD_HASH} />
    <meta http-equiv="refresh" content="120" />
    <title>{title} — Auto-Research</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Pre-paint theme resolution — must run before any rendered DOM to avoid FOUC.
        Default behaviour follows the system colour-scheme live (no localStorage).
        Explicit toggles save 'light' or 'dark' which then override the system. */}
    <script is:inline>
      (function () {
        function resolveTheme() {
          try {
            var saved = localStorage.getItem('ar-theme');
            if (saved === 'light' || saved === 'dark') return saved;
          } catch (e) {}
          // No explicit preference — follow system, defaulting to light when undetermined
          try {
            if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
          } catch (e) {}
          return 'light';
        }
        document.documentElement.dataset.theme = resolveTheme();
        // Live-track system changes when there's no explicit user preference
        try {
          var mq = window.matchMedia('(prefers-color-scheme: dark)');
          var onSysChange = function (e) {
            var saved = null;
            try { saved = localStorage.getItem('ar-theme'); } catch (_) {}
            if (saved === 'light' || saved === 'dark') return;     // explicit choice wins
            var next = e.matches ? 'dark' : 'light';
            if (document.documentElement.dataset.theme === next) return;
            document.documentElement.dataset.theme = next;
            if (window.__mermaidInit && window.__mermaidRender) {
              window.__mermaidInit(next); window.__mermaidRender();
            }
          };
          if (mq.addEventListener) mq.addEventListener('change', onSysChange);
          else if (mq.addListener) mq.addListener(onSysChange);
        } catch (e) {}
      })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" integrity="sha384-7zkQWkzuo3B5mTepMUcHkMB5jZaolc2xDwL6VFqjFALcbeS9Ggm/Yr2r3Dy4lfFg" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk" crossorigin="anonymous"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof renderMathInElement !== 'function') return;
        renderMathInElement(document.body, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '\\(', right: '\\)', display: false },
            { left: '\\[', right: '\\]', display: true },
          ],
          throwOnError: false,
          ignoredTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
        });
      });
    </script>

    {/* Mermaid for tree DAG visualisations — palette tracks data-theme.
        We disable startOnLoad so the toggle handler can cache the source
        textContent first (mermaid destroys it on render), then run. */}
    <script type="module" is:inline>
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
      window.__mermaid = mermaid;
      window.__mermaidVarsFor = (theme) => theme === 'dark'
        ? { primaryColor: '#25221e', primaryTextColor: '#e5e2d8', primaryBorderColor: '#9c9789', lineColor: '#9c9789' }
        : { primaryColor: '#fafaf7', primaryTextColor: '#1a1a1a', primaryBorderColor: '#4a4a4a', lineColor: '#4a4a4a' };
      window.__mermaidInit = (theme) => {
        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          themeVariables: { fontFamily: 'Inter, system-ui, sans-serif', fontSize: '15px', ...window.__mermaidVarsFor(theme) },
          securityLevel: 'loose',
          flowchart: { useMaxWidth: true, htmlLabels: false, curve: 'basis', nodeSpacing: 18, rankSpacing: 50, padding: 10 },
        });
      };
      window.__mermaidRender = () => {
        document.querySelectorAll('.mermaid').forEach((el) => {
          if (!el.dataset.source) el.dataset.source = el.textContent;       // cache once
          el.innerHTML = el.dataset.source;                                  // restore on every render
          el.removeAttribute('data-processed');
        });
        try { mermaid.run(); } catch (e) { console.error('mermaid.run failed', e); }
      };
      // Initial render at DOMContentLoaded with the boot-time theme
      const bootTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      window.__mermaidInit(bootTheme);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', window.__mermaidRender);
      } else {
        window.__mermaidRender();
      }
    </script>
    <style>
      .mermaid { display: flex; justify-content: center; }
      .mermaid svg { max-width: 100% !important; width: 100% !important; height: auto !important; }
      .mermaid .node rect, .mermaid .node circle, .mermaid .node ellipse, .mermaid .node polygon { rx: 6; ry: 6; }
      .mermaid .nodeLabel { font-weight: 700; font-size: 15px !important; line-height: 1.25 !important; }
    </style>

    {/* Tippy.js for hover tooltips on glossary terms + source citations */}
    <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/dist/tippy.css" />
    <script defer src="https://unpkg.com/@popperjs/core@2"></script>
    <script defer src="https://unpkg.com/tippy.js@6"></script>

    {/* Pagefind search UI (indexed at build time, served from /pagefind/) */}
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script src="/pagefind/pagefind-ui.js" defer></script>
    <script is:inline define:vars={{ payload: tooltipPayload, slug: report.slug }}>
      window.__tooltipPayload = payload;
      window.__reportSlug = slug;
    </script>
    <script is:inline src="/tooltips.js"></script>
    <script is:inline define:vars={{ BUILD_HASH }}>
      const LOG_PREFIX = '[live-reload]';
      console.log(LOG_PREFIX, 'embedded BUILD_HASH:', BUILD_HASH);
      async function checkAndReload() {
        const badge = document.getElementById('freshness-badge');
        const setBadge = (text, title, color) => {
          if (!badge) return;
          badge.textContent = text;
          badge.title = title;
          if (color) badge.style.color = color;
        };
        try {
          console.log(LOG_PREFIX, 'fetching /build-hash.txt');
          const resp = await fetch('/build-hash.txt?cb=' + Date.now(), {
            cache: 'no-store',
            headers: { 'Cache-Control': 'no-cache' },
          });
          console.log(LOG_PREFIX, 'fetch returned status', resp.status);
          if (!resp.ok) {
            setBadge('?', 'HTTP ' + resp.status, '#d97706');
            return;
          }
          const live = (await resp.text()).trim();
          console.log(LOG_PREFIX, 'live build-hash:', live, '==', BUILD_HASH, '?', live === BUILD_HASH);
          if (live && live !== BUILD_HASH) {
            setBadge('↻', 'newer deploy detected, reloading…', '#c4622d');
            console.log(LOG_PREFIX, 'mismatch — reloading');
            const url = new URL(location.href);
            url.searchParams.set('v', live);
            location.replace(url.toString());
            return;
          }
          setBadge('✓', 'latest (checked ' + new Date().toLocaleTimeString() + ')', '#2d6a4f');
        } catch (e) {
          console.error(LOG_PREFIX, 'check error:', e);
          setBadge('⚠', 'check error: ' + e + ' — click footer Reload to force', '#b91c1c');
        }
      }
      function forceReload() {
        const url = new URL(location.href);
        url.searchParams.set('v', String(Date.now()));
        location.replace(url.toString());
      }
      window.__forceReload = forceReload;
      (async () => {
        try {
          if ('serviceWorker' in navigator) {
            const regs = await navigator.serviceWorker.getRegistrations();
            for (const r of regs) { try { await r.unregister(); } catch {} }
          }
        } catch {}
        checkAndReload();
      })();
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') checkAndReload();
      });
      window.addEventListener('pageshow', () => checkAndReload());
      window.addEventListener('focus', () => checkAndReload());
      setInterval(checkAndReload, 30000);
    </script>
  </head>
  <body class="min-h-screen">
    {/* Search modal — opens on Cmd+K / Ctrl+K */}
    <div id="search-modal" class="hidden fixed inset-0 z-50 bg-black/40" onclick="window.__closeSearch()">
      <div class="max-w-2xl mx-auto mt-20 bg-[var(--color-paper)] border border-[var(--color-line)] rounded-lg shadow-2xl" onclick="event.stopPropagation()">
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">Search the report</span>
            <span class="text-xs font-mono text-[var(--color-ink-soft)]">esc to close</span>
          </div>
          <div id="search-target"></div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        let initialised = false;
        let selectedIdx = -1;
        function tryInit() {
          if (initialised) return;
          if (typeof PagefindUI !== 'function') { return setTimeout(tryInit, 100); }
          new PagefindUI({
            element: '#search-target',
            showSubResults: true,
            resetStyles: false,
            showImages: false,
            translations: {
              placeholder: 'Search claims, leaves, sources, glossary…',
              zero_results: 'No matches for "[SEARCH_TERM]"',
            },
          });
          initialised = true;
        }

        function getResultLinks() {
          // Pagefind renders results inside #search-target. Each result is a
          // .pagefind-ui__result with an <a> wrapping the title.
          return Array.from(document.querySelectorAll('#search-target .pagefind-ui__result a'));
        }

        function highlight(idx) {
          const links = getResultLinks();
          if (links.length === 0) return;
          if (idx < 0) idx = links.length - 1;
          if (idx >= links.length) idx = 0;
          selectedIdx = idx;
          links.forEach((a, i) => {
            if (i === idx) {
              a.style.background = 'var(--color-paper-dim)';
              a.style.outline = '2px solid var(--color-accent)';
              a.style.outlineOffset = '2px';
              a.scrollIntoView({ block: 'nearest' });
            } else {
              a.style.background = '';
              a.style.outline = '';
            }
          });
        }

        function openSelected() {
          const links = getResultLinks();
          if (selectedIdx >= 0 && selectedIdx < links.length) {
            links[selectedIdx].click();
          } else if (links.length > 0) {
            links[0].click();
          }
        }

        function closeSearch() {
          document.getElementById('search-modal').classList.add('hidden');
          selectedIdx = -1;
        }
        window.__closeSearch = closeSearch;

        document.addEventListener('keydown', (e) => {
          const modal = document.getElementById('search-modal');
          const isOpen = modal && !modal.classList.contains('hidden');

          // Cmd+K / Ctrl+K toggles open
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            tryInit();
            if (isOpen) {
              closeSearch();
            } else {
              modal.classList.remove('hidden');
              setTimeout(() => {
                const inp = modal.querySelector('input');
                if (inp) inp.focus();
              }, 50);
            }
            return;
          }

          if (!isOpen) return;

          if (e.key === 'Escape') {
            closeSearch();
            return;
          }
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            highlight(selectedIdx + 1);
            return;
          }
          if (e.key === 'ArrowUp') {
            e.preventDefault();
            highlight(selectedIdx - 1);
            return;
          }
          if (e.key === 'Enter') {
            const inp = modal.querySelector('input');
            // If a result is highlighted, open it. Otherwise let Enter run a search.
            if (selectedIdx >= 0) {
              e.preventDefault();
              openSelected();
            } else if (inp && inp.value && getResultLinks().length > 0) {
              e.preventDefault();
              highlight(0);
              openSelected();
            }
            return;
          }
        });

        // Reset highlight when user types in the search box
        document.addEventListener('input', (e) => {
          if (e.target && e.target.closest && e.target.closest('#search-target')) {
            selectedIdx = -1;
          }
        });
      })();
    </script>

    {/* AI-generated-content disclaimer — dismissible but reappears each session.
        Persists dismissal in sessionStorage so it returns on next visit. */}
    <div
      id="ai-disclaimer"
      class="bg-[var(--color-warn)]/8 border-b-2 border-[var(--color-warn)] text-sm"
      style="display: none;"
    >
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-start gap-3">
        <svg class="w-5 h-5 mt-0.5 shrink-0 text-[var(--color-warn)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 9v4M12 17h.01" />
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
        </svg>
        <div class="flex-1">
          <strong class="text-[var(--color-ink)]">Experiment in AI-generated analysis.</strong>
          <span class="text-[var(--color-ink-soft)]"> This report is produced by a multi-pass agentic engine — Claude as primary author, Codex as critic. Every claim was Codex-audited, but the substrate is still AI-generated and the engine is in active development. <strong class="text-[var(--color-ink)]">Extreme scrutiny is warranted.</strong> Cross-check load-bearing numbers against primary sources before acting on them. Flag anything that looks off; see the Pass Log for the full audit trail.</span>
        </div>
        <button
          id="ai-disclaimer-close"
          type="button"
          aria-label="Dismiss disclaimer"
          class="shrink-0 text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] transition-colors text-xs font-mono px-2 py-0.5 rounded border border-[var(--color-line)] hover:border-[var(--color-accent)]"
        >dismiss ✕</button>
      </div>
    </div>
    <script is:inline>
      (function () {
        var el = document.getElementById('ai-disclaimer');
        var btn = document.getElementById('ai-disclaimer-close');
        if (!el || !btn) return;
        var dismissed = false;
        try { dismissed = sessionStorage.getItem('ai-disclaimer-dismissed') === '1'; } catch (e) {}
        if (!dismissed) el.style.display = '';
        btn.addEventListener('click', function () {
          el.style.display = 'none';
          try { sessionStorage.setItem('ai-disclaimer-dismissed', '1'); } catch (e) {}
        });
      })();
    </script>

    <header class="border-b border-[var(--color-line)] bg-[var(--color-paper)]">
      <div class="max-w-6xl mx-auto px-6 py-4">
        <div class="flex items-baseline justify-between mb-3">
          <div class="text-sm text-[var(--color-ink-soft)] flex items-center gap-2 flex-wrap">
            <a href="/" class="hover:text-[var(--color-accent)] flex items-baseline gap-1.5">
              ← Auto-Research
              <span
                class="text-[10px] font-mono font-bold px-1.5 py-0.5 rounded border"
                style="background: var(--color-warn); color: var(--color-paper); border-color: var(--color-warn); letter-spacing: 0.05em;"
                title={`Engine ${SITE_VERSION} — in active development; expect change`}
              >{SITE_STAGE} {SITE_VERSION}</span>
            </a>
            <span class="text-[var(--color-line)]">/</span>
            <a href={`/${report.slug}/`} class="font-mono text-xs hover:text-[var(--color-accent)]">{report.slug}</a>
          </div>
          <div class="text-xs text-[var(--color-ink-soft)] font-mono">
            pass #{report.meta.current_pass} · {report.meta.status}
          </div>
        </div>
        <h1 class="text-2xl font-serif font-semibold text-[var(--color-ink)] leading-snug">
          {report.meta.root_question}
        </h1>
      </div>
      <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between -mb-px">
        <div class="flex gap-6">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                'pb-3 text-sm border-b-2 transition-colors',
                activeTab === tab.id
                  ? 'border-[var(--color-accent)] text-[var(--color-accent)] font-medium'
                  : 'border-transparent text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]',
              ]}
            >
              {tab.label}
            </a>
          ))}
        </div>
        <div class="flex items-center gap-4 pb-3">
          <button
            id="theme-toggle"
            type="button"
            class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] transition-colors flex items-center"
            aria-label="Toggle dark mode"
            title="Toggle dark / light mode"
          >
            {/* Sun (shown in dark mode = click to switch to light) */}
            <svg class="w-4 h-4 hidden [html[data-theme='dark']_&]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
            {/* Moon (shown in light mode = click to switch to dark) */}
            <svg class="w-4 h-4 [html[data-theme='dark']_&]:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
          <button
            onclick="document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true }))"
            class="text-xs text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] flex items-center gap-1"
            title="Search the report (Cmd+K)"
          >
            <span>Search</span>
            <kbd class="font-mono px-1.5 py-0.5 rounded border border-[var(--color-line)] bg-[var(--color-paper-dim)] text-[10px]">⌘K</kbd>
          </button>
        </div>
      </nav>
      <script is:inline>
        (function () {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;
          btn.addEventListener('click', () => {
            const cur = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
            const next = cur === 'dark' ? 'light' : 'dark';
            document.documentElement.dataset.theme = next;
            try { localStorage.setItem('ar-theme', next); } catch (e) {}
            if (window.__mermaidInit && window.__mermaidRender) {
              window.__mermaidInit(next);
              window.__mermaidRender();
            }
          });
        })();
      </script>
    </header>
    <main class="max-w-6xl mx-auto px-6 py-8">
      <slot />
    </main>
    <footer class="max-w-6xl mx-auto px-6 py-6 mt-12 border-t border-[var(--color-line)] text-xs text-[var(--color-ink-soft)] flex justify-between items-center">
      <div>report data updated {reportUpdatedStr}</div>
      <div class="flex items-center gap-2">
        <span>site built <span class="font-mono">{buildTime}</span></span>
        <span id="freshness-badge" class="px-1.5 py-0.5 rounded bg-[var(--color-paper-dim)]" title="checking for new deploys...">⏳</span>
        <button
          onclick="window.__forceReload && window.__forceReload()"
          class="ml-1 px-2 py-0.5 rounded border border-[var(--color-line)] hover:bg-[var(--color-paper-dim)] hover:border-[var(--color-accent)] transition-colors"
          title="Force reload bypassing any cache"
        >↻ reload</button>
      </div>
    </footer>
  </body>
</html>
