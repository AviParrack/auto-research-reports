---
import ModelLayout from '../../../layouts/ModelLayout.astro';
import EvidenceChip from '../../../components/EvidenceChip.astro';
import { loadAllModels, loadModel, entityFor, entityLink } from '../../../lib/models';

export function getStaticPaths() {
  return loadAllModels().map((m) => ({ params: { model: m.slug } }));
}

const { model: slug } = Astro.params;
const model = loadModel(slug!);
const fmt = (v?: number) => (v == null ? '—' : v.toLocaleString() + ' MJ');
---
<ModelLayout model={model} title={`Energetic Index — ${model.meta.product}`} activeTab="energetic">
  <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-1">Energetic idiot index</h2>
  <p class="text-xs text-[var(--color-ink-soft)] mb-5 max-w-3xl">
    <span class="font-mono">I_E = actual cradle-to-gate energy ÷ thermodynamic floor</span>. The joules-based, "above Musk" lens: how far the actual energy to make a unit sits above the minimum the physics demands for the same atoms (mining, reduction, purification, crystal growth, fab). Each side carries a citation or a labelled estimate.
  </p>

  <div class="space-y-4">
    {model.energeticIndex.map((row) => {
      const ent = entityFor(model, row.entity);
      const link = entityLink(model, row.entity);
      return (
        <div class="border border-[var(--color-line)] rounded-lg p-5">
          <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
            <div>
              <h3 class="font-serif text-lg font-semibold text-[var(--color-ink)]">{row.product}</h3>
              {ent && <div class="text-xs text-[var(--color-ink-soft)]">{link ? <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined} class="hover:text-[var(--color-accent)]">{ent.name} {link.external ? '↗' : '→'}</a> : ent.name}</div>}
            </div>
            <div class="text-right">
              <div class="text-3xl font-serif font-bold text-[var(--color-leaf)]">{row.ratio != null ? row.ratio.toLocaleString() + '×' : '—'}</div>
              {row.confidence && <div class="text-[11px] uppercase tracking-wide text-[var(--color-ink-soft)]">{row.confidence} confidence</div>}
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="bg-[var(--color-paper-dim)] rounded p-3">
              <div class="text-[11px] uppercase tracking-wider text-[var(--color-ink-soft)] mb-1">Actual · {row.actual.label}</div>
              <div class="flex items-baseline justify-between">
                <span class="text-lg font-mono text-[var(--color-ink)]">{fmt(row.actual.value_mj)}</span>
                <EvidenceChip evidence={row.actual.evidence} modelSlug={model.slug} />
              </div>
            </div>
            <div class="bg-[var(--color-paper-dim)] rounded p-3">
              <div class="text-[11px] uppercase tracking-wider text-[var(--color-ink-soft)] mb-1">Floor · {row.floor.label}</div>
              <div class="flex items-baseline justify-between">
                <span class="text-lg font-mono text-[var(--color-ink)]">{fmt(row.floor.value_mj)}</span>
                <EvidenceChip evidence={row.floor.evidence} modelSlug={model.slug} />
              </div>
            </div>
          </div>
          {row.note && <p class="text-[11px] text-[var(--color-ink-soft)] mt-2">{row.note}</p>}
        </div>
      );
    })}
    {model.energeticIndex.length === 0 && <div class="text-[var(--color-ink-soft)]">No energetic-index rows yet.</div>}
  </div>
</ModelLayout>
