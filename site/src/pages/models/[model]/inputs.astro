---
import ModelLayout from '../../../layouts/ModelLayout.astro';
import EvidenceChip from '../../../components/EvidenceChip.astro';
import { loadAllModels, loadModel } from '../../../lib/models';

export function getStaticPaths() {
  return loadAllModels().map((m) => ({ params: { model: m.slug } }));
}

const { model: slug } = Astro.params;
const model = loadModel(slug!);
---
<ModelLayout model={model} title={`Inputs — ${model.meta.product}`} activeTab="inputs">
  <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-1">Input decomposition (BOM)</h2>
  <p class="text-xs text-[var(--color-ink-soft)] mb-5 max-w-3xl">Every relevant input, what fraction of the final product it represents by mass and by value, and where it sits in the stack. The gap between "fraction of mass" and "fraction of value" is the idiot index in miniature.</p>

  <div class="overflow-x-auto border border-[var(--color-line)] rounded-lg">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-[var(--color-paper-dim)] text-left text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">
          <th class="px-4 py-3 font-medium">Component</th>
          <th class="px-4 py-3 font-medium">Stage</th>
          <th class="px-4 py-3 font-medium">% of mass</th>
          <th class="px-4 py-3 font-medium">% of value</th>
          <th class="px-4 py-3 font-medium">Source</th>
        </tr>
      </thead>
      <tbody>
        {model.inputs.map((it) => (
          <tr class="border-t border-[var(--color-line)] hover:bg-[var(--color-paper-dim)]">
            <td class="px-4 py-3 font-medium text-[var(--color-ink)]">{it.component}</td>
            <td class="px-4 py-3 text-[var(--color-ink-soft)]"><span class="font-mono text-xs">{it.stage}</span></td>
            <td class="px-4 py-3 text-[var(--color-ink-soft)]">{it.pct_of_mass}</td>
            <td class="px-4 py-3 text-[var(--color-ink-soft)]">{it.pct_of_value}</td>
            <td class="px-4 py-3"><EvidenceChip evidence={it.evidence} modelSlug={model.slug} /></td>
          </tr>
        ))}
        {model.inputs.length === 0 && (
          <tr><td colspan="5" class="px-4 py-6 text-center text-[var(--color-ink-soft)]">No inputs yet.</td></tr>
        )}
      </tbody>
    </table>
  </div>
</ModelLayout>
