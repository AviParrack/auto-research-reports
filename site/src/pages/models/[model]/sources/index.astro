---
import ModelLayout from '../../../../layouts/ModelLayout.astro';
import { loadAllModels, loadModel, renderMath, type ModelSource } from '../../../../lib/models';

export function getStaticPaths() {
  return loadAllModels().map((m) => ({ params: { model: m.slug } }));
}

const { model: slug } = Astro.params;
const model = loadModel(slug!);

const TIER_ORDER: Record<string, number> = { S: 0, A: 1, B: 2, C: 3, D: 4, E: 5 };
const sources = model.sources.slice().sort((a, b) => {
  const at = a.tier ? TIER_ORDER[a.tier] ?? 99 : 99;
  const bt = b.tier ? TIER_ORDER[b.tier] ?? 99 : 99;
  if (at !== bt) return at - bt;
  return (a.title || a.slug).localeCompare(b.title || b.slug);
});

type Facet = [string, number];
function facetCounts(key: 'tier' | 'type' | 'topic' | 'reviewed'): Facet[] {
  const map = new Map<string, number>();
  for (const s of sources) {
    if (key === 'tier') { const k = s.tier || '—'; map.set(k, (map.get(k) ?? 0) + 1); }
    else if (key === 'type') { const k = s.type || '—'; map.set(k, (map.get(k) ?? 0) + 1); }
    else if (key === 'topic') { for (const t of s.topics ?? []) map.set(t, (map.get(t) ?? 0) + 1); }
    else if (key === 'reviewed') { const k = s.reviewed ? 'reviewed' : 'unreviewed'; map.set(k, (map.get(k) ?? 0) + 1); }
  }
  return [...map.entries()].sort((a, b) => b[1] - a[1]);
}
const tierFacets = facetCounts('tier');
const typeFacets = facetCounts('type');
const topicFacets = facetCounts('topic');
const reviewedFacets = facetCounts('reviewed');

function preview(body: string, max = 280): string {
  const stripped = body.replace(/^#\s+[^\n]+\n+/, '').replace(/^---[\s\S]*?---/, '').trim();
  if (stripped.length <= max) return stripped;
  const cut = stripped.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return cut.slice(0, lastSpace > 0 ? lastSpace : max) + '…';
}

function tierColors(tier?: string): { bg: string; fg: string; border: string } {
  switch (tier) {
    case 'S': return { bg: 'var(--color-accent)', fg: '#fff', border: 'var(--color-accent)' };
    case 'A': return { bg: 'color-mix(in srgb, var(--color-leaf) 18%, transparent)', fg: 'var(--color-leaf)', border: 'var(--color-leaf)' };
    case 'B': return { bg: 'color-mix(in srgb, var(--color-warn) 18%, transparent)', fg: 'var(--color-warn)', border: 'var(--color-warn)' };
    case 'C': return { bg: 'var(--color-paper-dim)', fg: 'var(--color-ink-soft)', border: 'var(--color-line)' };
    default:  return { bg: 'transparent', fg: 'var(--color-unaudited)', border: 'var(--color-unaudited)' };
  }
}
function alignmentScore(s: ModelSource): number {
  const c = s.reviewSummary;
  if (!c) return -999;
  return (c.consistent + c.novelSupporting) - (c.differentConclusion + c.meritsInvestigation);
}
---
<ModelLayout model={model} title={`References — ${model.meta.product}`} activeTab="sources">
  <div class="mb-4">
    <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-2">References ({sources.length})</h2>
    <p class="text-sm text-[var(--color-ink-soft)] max-w-3xl">Every source cited in the model, tier-coded per the source-hierarchy spec. Each <span class="font-mono">cite</span> chip elsewhere links here. Click a source for its full extract + review.</p>
  </div>

  {/* Stats strip */}
  <section class="mb-4 grid grid-cols-2 md:grid-cols-6 gap-2 text-xs">
    <div class="border border-[var(--color-line)] rounded p-2">
      <div class="font-mono text-lg">{sources.length}</div>
      <div class="text-[var(--color-ink-soft)] uppercase tracking-wider">total</div>
    </div>
    <div class="border border-[var(--color-line)] rounded p-2">
      <div class="font-mono text-lg text-[var(--color-leaf)]">{sources.filter(s => s.reviewed).length}</div>
      <div class="text-[var(--color-ink-soft)] uppercase tracking-wider">reviewed</div>
    </div>
    {(['S', 'A', 'B', 'C'] as const).map((t) => {
      const n = sources.filter(s => s.tier === t).length;
      const colors = tierColors(t);
      return (
        <div class="border border-[var(--color-line)] rounded p-2">
          <div class="flex items-baseline gap-1">
            <span class="inline-block px-1.5 py-0 rounded text-[10px] font-bold" style={`background:${colors.bg};color:${colors.fg};border:1px solid ${colors.border};`}>{t}</span>
            <span class="font-mono text-lg">{n}</span>
          </div>
          <div class="text-[var(--color-ink-soft)] uppercase tracking-wider text-[10px]">tier {t.toLowerCase()}</div>
        </div>
      );
    })}
  </section>

  {/* Filter + sort controls */}
  <section id="source-controls" class="mb-5 border border-[var(--color-line)] rounded p-3 text-xs">
    {tierFacets.length > 0 && (
      <div class="flex items-baseline gap-2 mb-2 flex-wrap">
        <span class="text-[var(--color-ink-soft)] uppercase tracking-wider shrink-0">Tier:</span>
        {tierFacets.map(([t, n]) => {
          const colors = tierColors(t === '—' ? undefined : t);
          return (
            <button type="button" data-filter="tier" data-value={t}
              class="px-2 py-0.5 rounded border font-mono hover:bg-[var(--color-paper-dim)] transition-colors data-[active=true]:bg-[var(--color-accent)] data-[active=true]:text-white data-[active=true]:border-[var(--color-accent)]"
              style={`border-color:${colors.border};color:${colors.fg};`}>{t} <span class="opacity-60">{n}</span></button>
          );
        })}
      </div>
    )}
    <div class="flex items-baseline gap-2 mb-2 flex-wrap">
      <span class="text-[var(--color-ink-soft)] uppercase tracking-wider shrink-0">Status:</span>
      {reviewedFacets.map(([k, n]) => (
        <button type="button" data-filter="reviewed" data-value={k}
          class="px-2 py-0.5 rounded border border-[var(--color-line)] font-mono hover:bg-[var(--color-paper-dim)] transition-colors data-[active=true]:bg-[var(--color-accent)] data-[active=true]:text-white data-[active=true]:border-[var(--color-accent)]">{k} <span class="opacity-60">{n}</span></button>
      ))}
    </div>
    {typeFacets.length > 0 && (
      <details class="mb-2">
        <summary class="cursor-pointer text-[var(--color-ink-soft)] uppercase tracking-wider">Type ({typeFacets.length})</summary>
        <div class="flex flex-wrap gap-2 mt-2">
          {typeFacets.map(([k, n]) => (
            <button type="button" data-filter="type" data-value={k}
              class="px-2 py-0.5 rounded border border-[var(--color-line)] font-mono hover:bg-[var(--color-paper-dim)] transition-colors data-[active=true]:bg-[var(--color-accent)] data-[active=true]:text-white data-[active=true]:border-[var(--color-accent)]">{k} <span class="opacity-60">{n}</span></button>
          ))}
        </div>
      </details>
    )}
    {topicFacets.length > 0 && (
      <details class="mb-2">
        <summary class="cursor-pointer text-[var(--color-ink-soft)] uppercase tracking-wider">Topic ({topicFacets.length})</summary>
        <div class="flex flex-wrap gap-2 mt-2">
          {topicFacets.map(([k, n]) => (
            <button type="button" data-filter="topic" data-value={k}
              class="px-2 py-0.5 rounded border border-[var(--color-line)] font-mono hover:bg-[var(--color-paper-dim)] transition-colors data-[active=true]:bg-[var(--color-accent)] data-[active=true]:text-white data-[active=true]:border-[var(--color-accent)]">{k} <span class="opacity-60">{n}</span></button>
          ))}
        </div>
      </details>
    )}
    <div class="flex items-center justify-between gap-3 mt-2 pt-2 border-t border-[var(--color-line)]">
      <div class="flex items-center gap-2">
        <label for="source-sort" class="text-[var(--color-ink-soft)] uppercase tracking-wider">Sort:</label>
        <select id="source-sort" class="bg-[var(--color-paper-dim)] border border-[var(--color-line)] px-2 py-1 rounded font-mono">
          <option value="tier">Tier (S→D)</option>
          <option value="title">Title (A→Z)</option>
          <option value="year-desc">Year (newest)</option>
          <option value="year-asc">Year (oldest)</option>
          <option value="type">Type</option>
          <option value="alignment">Alignment (most consistent)</option>
          <option value="review-depth">Review depth (most claims)</option>
        </select>
      </div>
      <button type="button" id="source-clear" class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] underline">clear filters</button>
    </div>
    <div id="source-result-count" class="text-[var(--color-ink-soft)] mt-2 font-mono"></div>
  </section>

  {sources.length === 0 ? (
    <div class="border border-[var(--color-line)] rounded p-6 text-[var(--color-ink-soft)]">No sources captured yet.</div>
  ) : (
    <ul id="source-list" class="space-y-3">
      {sources.map((s) => {
        const tc = tierColors(s.tier);
        const c = s.reviewSummary;
        return (
        <li class="border border-[var(--color-line)] rounded p-4 data-[hidden=true]:hidden"
            data-slug={s.slug}
            data-tier={s.tier || ''}
            data-type={s.type || ''}
            data-topics={(s.topics || []).join(' ')}
            data-reviewed={s.reviewed ? 'reviewed' : 'unreviewed'}
            data-year={typeof s.year === 'number' ? s.year : parseInt(String(s.year || '0'), 10) || 0}
            data-title={(s.title || s.slug).toLowerCase()}
            data-alignment={alignmentScore(s)}
            data-review-depth={c?.total || 0}>
          <div class="flex items-baseline gap-3 mb-1">
            {s.tier && <span class="text-xs font-bold px-1.5 rounded shrink-0" style={`background:${tc.bg};color:${tc.fg};border:1px solid ${tc.border};`} title={`Tier ${s.tier}`}>{s.tier}</span>}
            <a href={`/models/${model.slug}/sources/${s.slug}/`} class="font-medium hover:text-[var(--color-accent)] flex-1">{s.title || s.slug}</a>
            <div class="text-xs font-mono text-[var(--color-ink-soft)] shrink-0 flex items-center gap-2">
              {s.year && <span>{s.year}</span>}
              {s.type && <span class="px-1.5 py-0.5 bg-[var(--color-paper-dim)] rounded">{s.type}</span>}
              {s.reviewed ? <span class="text-[var(--color-leaf)]">✓ reviewed</span> : s.scaffold ? <span class="text-[var(--color-warn)]">🧪 stub</span> : null}
            </div>
          </div>
          <div class="text-xs text-[var(--color-ink-soft)] font-mono mb-2 flex items-center gap-3 flex-wrap">
            <a href={`/models/${model.slug}/sources/${s.slug}/`} class="hover:text-[var(--color-accent)]">{s.slug}</a>
            {s.authors && s.authors.length > 0 && <span>{s.authors.join(', ')}</span>}
            {s.url && <a href={s.url} target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">↗</a>}
          </div>
          {c && c.total > 0 && (
            <div class="flex items-center gap-2 mb-2 text-xs flex-wrap">
              <span class="text-[var(--color-ink-soft)] uppercase tracking-wider">verdicts:</span>
              {c.consistent > 0 && <span class="px-1.5 py-0.5 rounded" style="background: color-mix(in srgb, var(--color-leaf) 15%, transparent); color: var(--color-leaf);">✓ {c.consistent} consistent</span>}
              {c.novelSupporting > 0 && <span class="px-1.5 py-0.5 rounded" style="background: color-mix(in srgb, var(--color-leaf) 15%, transparent); color: var(--color-leaf);">★ {c.novelSupporting} novel</span>}
              {c.differentConclusion > 0 && <span class="px-1.5 py-0.5 rounded" style="background: color-mix(in srgb, var(--color-flag) 15%, transparent); color: var(--color-flag);">◆ {c.differentConclusion} different</span>}
              {c.meritsInvestigation > 0 && <span class="px-1.5 py-0.5 rounded" style="background: color-mix(in srgb, var(--color-warn) 15%, transparent); color: var(--color-warn);">🔍 {c.meritsInvestigation} merits</span>}
              {c.notRelevant > 0 && <span class="px-1.5 py-0.5 rounded text-[var(--color-ink-soft)]">○ {c.notRelevant} n/a</span>}
            </div>
          )}
          <div class="text-sm text-[var(--color-ink-soft)] leading-relaxed mb-2 prose-leaf" set:html={renderMath(preview(s.body), { inline: true })} />
          {s.topics && s.topics.length > 0 && (
            <div class="flex flex-wrap gap-1 justify-end">
              {s.topics.slice(0, 5).map((t) => (
                <span class="px-1.5 py-0.5 bg-[var(--color-paper-dim)] rounded font-mono text-[10px] text-[var(--color-ink-soft)]">{t}</span>
              ))}
            </div>
          )}
        </li>);
      })}
    </ul>
  )}

  <script is:inline>
    (function () {
      const TIER_RANK = { S: 0, A: 1, B: 2, C: 3, D: 4, E: 5, '': 99 };
      const list = document.getElementById('source-list');
      if (!list) return;
      const controls = document.getElementById('source-controls');
      const counter = document.getElementById('source-result-count');
      const sortSel = document.getElementById('source-sort');
      const clearBtn = document.getElementById('source-clear');
      const active = { tier: new Set(), type: new Set(), topic: new Set(), reviewed: new Set() };

      function applyFilters() {
        const items = Array.from(list.children);
        let shown = 0;
        for (const li of items) {
          let visible = true;
          for (const dim of Object.keys(active)) {
            if (active[dim].size === 0) continue;
            const attrName = dim === 'topic' ? 'topics' : dim;
            const raw = li.getAttribute('data-' + attrName) || '';
            const tokens = dim === 'topic' ? raw.split(/\s+/).filter(Boolean) : [raw];
            const hit = Array.from(active[dim]).some((v) => tokens.includes(v));
            if (!hit) { visible = false; break; }
          }
          li.dataset.hidden = visible ? 'false' : 'true';
          if (visible) shown++;
        }
        if (counter) counter.textContent = shown + ' of ' + items.length + ' sources shown';
      }
      function applySort() {
        const key = sortSel ? sortSel.value : 'tier';
        const items = Array.from(list.children);
        items.sort((a, b) => {
          switch (key) {
            case 'title': return a.dataset.title.localeCompare(b.dataset.title);
            case 'year-desc': return (+b.dataset.year) - (+a.dataset.year);
            case 'year-asc': return (+a.dataset.year) - (+b.dataset.year);
            case 'type': return (a.dataset.type || '').localeCompare(b.dataset.type || '');
            case 'alignment': return (+b.dataset.alignment) - (+a.dataset.alignment);
            case 'review-depth': return (+b.dataset.reviewDepth) - (+a.dataset.reviewDepth);
            default: {
              const ar = TIER_RANK[a.dataset.tier || ''] ?? 99;
              const br = TIER_RANK[b.dataset.tier || ''] ?? 99;
              if (ar !== br) return ar - br;
              return a.dataset.title.localeCompare(b.dataset.title);
            }
          }
        });
        for (const item of items) list.appendChild(item);
      }
      controls.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-filter]');
        if (!btn) return;
        const dim = btn.dataset.filter, val = btn.dataset.value;
        if (active[dim].has(val)) { active[dim].delete(val); btn.dataset.active = 'false'; }
        else { active[dim].add(val); btn.dataset.active = 'true'; }
        applyFilters();
      });
      if (sortSel) sortSel.addEventListener('change', applySort);
      if (clearBtn) clearBtn.addEventListener('click', () => {
        for (const dim of Object.keys(active)) active[dim].clear();
        controls.querySelectorAll('button[data-filter]').forEach((b) => { b.dataset.active = 'false'; });
        applyFilters();
      });
      applyFilters();
    })();
  </script>
</ModelLayout>
