---
import ReportLayout from '../../layouts/ReportLayout.astro';
import { listReportSlugs, loadReport, getNodeChildren, renderMath, loadLatestSynthesis, rewriteSynthesisFigureUrls } from '../../lib/reports';

export function getStaticPaths() {
  return listReportSlugs().map((slug) => ({ params: { report: slug } }));
}

const { report: slug } = Astro.params;
const report = loadReport(slug!);

const topLevel = getNodeChildren(report.tree, 'root');
const leafNodes = report.tree.nodes.filter((n) => n.type === 'leaf');
const leafCount = leafNodes.length;
// Count "answered" by the leaf.yaml status (source of truth for completion),
// not tree.yaml node.status (which is only updated by synthesis pass).
const answeredCount = leafNodes.filter((n) => {
  const leaf = report.leaves.find((l) => l.id === n.id);
  if (!leaf) return false;
  return leaf.status === 'reviewed' || leaf.status === 'done';
}).length;
const totalSubPasses = report.leaves.reduce((acc, l) => acc + Object.keys(l.passes_status).length, 0);
const doneSubPasses = report.leaves.reduce((acc, l) =>
  acc + Object.values(l.passes_status).filter((v) => v === 'done').length, 0);
const totalSources = new Set(report.leaves.flatMap((l) => l.sources.map((s) => s.slug))).size;

// Synthesis: latest v{N}/ under 03-synthesis/, primary = claude-v2 ?? claude-v1
const synthesis = loadLatestSynthesis(slug!);
const synthBody = synthesis?.primary
  ? rewriteSynthesisFigureUrls(synthesis.primary.body, slug!, synthesis.version)
  : null;
---
<ReportLayout report={report} title={report.meta.root_question} activeTab="report">
  <div class="grid md:grid-cols-3 gap-8">
    <section class="md:col-span-2 space-y-6">
      <div>
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)]">Report</h2>
          {synthesis && (
            <div class="flex items-center gap-3 text-xs text-[var(--color-ink-soft)]">
              <span class="font-mono">synthesis {synthesis.version}</span>
              <span>·</span>
              <a href={`/${slug}/synthesis/`} class="text-[var(--color-accent)] hover:underline">all versions</a>
            </div>
          )}
        </div>
        {synthBody ? (
          <article class="prose-leaf synthesis-body" set:html={renderMath(synthBody, { inline: false })} />
        ) : report.tree.root.answer ? (
          <div class="prose-leaf bg-[var(--color-paper-dim)] border-l-4 border-[var(--color-accent)] p-5 rounded-r">
            <p>{report.tree.root.answer}</p>
          </div>
        ) : (
          <div class="text-[var(--color-ink-soft)] italic">
            <p>The synthesis report has not yet been generated.</p>
            <p class="mt-3 text-sm">
              The engine is still gathering evidence across the question tree. See the <a href={`/${slug}/analysis/`} class="text-[var(--color-accent)] hover:underline">Analysis tab</a> for current state of the leaves.
            </p>
          </div>
        )}
      </div>
      <style>
        .synthesis-body img {
          display: block;
          margin: 1.5rem auto;
          max-width: 100%;
          height: auto;
          border: 1px solid var(--color-line);
          border-radius: 4px;
          padding: 4px;
          background: var(--color-paper);
        }
        .synthesis-body img + em {
          display: block;
          text-align: center;
          font-size: 0.875rem;
          color: var(--color-ink-soft);
          margin-top: -1rem;
          margin-bottom: 1.5rem;
        }
      </style>
    </section>

    <aside class="space-y-6">
      <div>
        <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Progress</h2>
        <div class="space-y-3">
          <div>
            <div class="flex items-baseline justify-between text-xs text-[var(--color-ink-soft)] mb-1">
              <span>Leaves answered</span>
              <span class="font-mono">{answeredCount} / {leafCount}</span>
            </div>
            <div class="h-2 bg-[var(--color-paper-dim)] rounded overflow-hidden">
              <div class="h-full bg-[var(--color-leaf)]" style={`width: ${leafCount === 0 ? 0 : Math.round((answeredCount/leafCount)*100)}%`}></div>
            </div>
          </div>
          <div>
            <div class="flex items-baseline justify-between text-xs text-[var(--color-ink-soft)] mb-1">
              <span>Sub-passes done</span>
              <span class="font-mono">{doneSubPasses} / {totalSubPasses}</span>
            </div>
            <div class="h-2 bg-[var(--color-paper-dim)] rounded overflow-hidden">
              <div class="h-full bg-[var(--color-accent)]" style={`width: ${totalSubPasses === 0 ? 0 : Math.round((doneSubPasses/totalSubPasses)*100)}%`}></div>
            </div>
          </div>
          <div class="text-xs text-[var(--color-ink-soft)] font-mono">
            {totalSources} source{totalSources === 1 ? '' : 's'} captured
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Termination</h2>
        <ul class="text-sm space-y-1">
          <li class="flex items-center gap-2">
            <span class={report.meta.termination.root_answered ? 'text-[var(--color-leaf)]' : 'text-[var(--color-unaudited)]'}>
              {report.meta.termination.root_answered ? '✓' : '○'}
            </span>
            <span>Root answered</span>
          </li>
          <li class="flex items-center gap-2">
            <span class={report.meta.termination.all_figures_reviewed ? 'text-[var(--color-leaf)]' : 'text-[var(--color-unaudited)]'}>
              {report.meta.termination.all_figures_reviewed ? '✓' : '○'}
            </span>
            <span>All major figures reviewed</span>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Root Question</h2>
        <div class="prose-leaf text-sm">{report.meta.root_question}</div>
      </div>

      <div>
        <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Models</h2>
        <ul class="text-sm font-mono space-y-1 text-[var(--color-ink-soft)]">
          <li>primary: {report.meta.models.primary}</li>
          <li>critic: {report.meta.models.critic}</li>
        </ul>
      </div>
    </aside>
  </div>
</ReportLayout>
