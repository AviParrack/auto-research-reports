---
import ReportLayout from '../../../layouts/ReportLayout.astro';
import { listReportSlugs, loadReport, buildMermaidTree, type TreeNode } from '../../../lib/reports';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return listReportSlugs().map((slug) => ({ params: { report: slug } }));
}

const { report: slug } = Astro.params;
const report = loadReport(slug!);

const leafNodes = report.tree.nodes.filter((n) => n.type === 'leaf');
const synthesisNodes = report.tree.nodes.filter((n) => n.type === 'synthesis');
const constraintNodes = report.tree.nodes.filter((n) => n.type === 'constraint');
const mermaidSyntax = buildMermaidTree(report, slug!);

// Load pass-log entries to derive per-leaf activity (sparkline + last-touched timestamp)
const REPORTS_DIR_ANALYSIS = path.resolve(process.cwd(), '../reports');
const logPath = path.join(REPORTS_DIR_ANALYSIS, slug!, 'pass-log.jsonl');
interface PassEntry { pass_id?: string; focus?: string; started?: string; }
let passEntries: PassEntry[] = [];
if (fs.existsSync(logPath)) {
  passEntries = fs.readFileSync(logPath, 'utf8').split('\n').filter(Boolean)
    .map((line) => { try { return JSON.parse(line) as PassEntry; } catch { return null; } })
    .filter((p): p is PassEntry => !!p);
}

// Report-wide time range — sparklines normalize to this so leaves are comparable
const allStarts = passEntries
  .map((p) => p.started ? new Date(p.started).getTime() : NaN)
  .filter((n) => !isNaN(n));
const reportStart = allStarts.length > 0 ? Math.min(...allStarts) : 0;
const reportEnd = allStarts.length > 0 ? Math.max(...allStarts) : reportStart + 1;
const reportSpan = Math.max(reportEnd - reportStart, 1);
const nowTs = Date.now();

interface LeafActivity { ticks: number[]; lastTouched: number; count: number; }
function leafActivity(leafId: string): LeafActivity | null {
  const ts = passEntries
    .filter((p) => p.focus === `leaf:${leafId}` && p.started)
    .map((p) => new Date(p.started!).getTime())
    .filter((n) => !isNaN(n))
    .sort((a, b) => a - b);
  if (ts.length === 0) return null;
  return {
    ticks: ts.map((t) => (t - reportStart) / reportSpan),
    lastTouched: ts[ts.length - 1],
    count: ts.length,
  };
}

function relativeTime(ts: number): string {
  const diff = nowTs - ts;
  const min = 60_000, hr = 3_600_000, day = 86_400_000;
  if (diff < min) return 'just now';
  if (diff < hr) return `${Math.round(diff / min)}m ago`;
  if (diff < day) return `${Math.round(diff / hr)}h ago`;
  if (diff < 7 * day) return `${Math.round(diff / day)}d ago`;
  return new Date(ts).toISOString().slice(0, 10);
}

function absTime(ts: number): string {
  return new Date(ts).toISOString().replace('T', ' ').slice(0, 16) + 'Z';
}

function leafFor(node: TreeNode) {
  return report.leaves.find((l) => l.id === node.id);
}
function progress(node: TreeNode) {
  const leaf = leafFor(node);
  if (!leaf) return { done: 0, total: 0 };
  const subs = Object.values(leaf.passes_status);
  return { done: subs.filter((s) => s === 'done').length, total: subs.length };
}
---
<ReportLayout report={report} title={`Analysis — ${report.meta.root_question}`} activeTab="analysis">
  <div class="mb-6">
    <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-2">Analysis</h2>
    <p class="text-sm text-[var(--color-ink-soft)] max-w-3xl">
      The question DAG decomposed into Input Questions (atomic factual leaves), Analyses (synthesis nodes that combine inputs), and Side Chapters (constraint or orthogonal deep-dives).
    </p>
  </div>

  <details class="mb-8 border border-[var(--color-line)] rounded" open>
    <summary class="cursor-pointer p-3 hover:bg-[var(--color-paper-dim)]/30">
      <span class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)]">Question DAG</span>
      <span class="ml-2 text-xs text-[var(--color-ink-soft)]">click any node to jump to its leaf</span>
    </summary>
    <div class="p-4 overflow-x-auto">
      <pre class="mermaid">{mermaidSyntax}</pre>
    </div>
  </details>

  {leafNodes.length > 0 && (
    <section class="mb-10">
      <h3 class="text-lg font-serif font-semibold mb-3">Input Questions (Leaf)</h3>
      <ul class="space-y-2">
        {leafNodes.map((node) => {
          const p = progress(node);
          const leaf = leafFor(node);
          const act = leafActivity(node.id);
          return (
          <li>
            <a href={`/${slug}/leaves/${node.id}/`} class="block border border-[var(--color-line)] rounded p-3 hover:border-[var(--color-accent)] hover:bg-[var(--color-paper-dim)]/30 transition-colors">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <div class="flex items-baseline gap-2 flex-1 min-w-0">
                  <span class="font-mono text-xs text-[var(--color-ink-soft)] shrink-0">{node.id}</span>
                  <span class="font-medium">{node.question}</span>
                </div>
                <span class:list={[
                  'text-xs px-2 py-0.5 rounded font-mono shrink-0',
                  node.status === 'answered' ? 'bg-[var(--color-leaf)]/15 text-[var(--color-leaf)]'
                  : p.done > 0 ? 'bg-[var(--color-warn)]/15 text-[var(--color-warn)]'
                  : 'bg-[var(--color-paper-dim)] text-[var(--color-ink-soft)]'
                ]}>
                  {node.status === 'answered' ? 'answered' : p.total > 0 ? `${p.done}/${p.total} done` : 'open'}
                </span>
              </div>
              {node.answer && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{node.answer}</p>}
              {leaf && (
                <div class="flex items-baseline justify-between gap-3 text-xs text-[var(--color-ink-soft)] mt-1.5">
                  <div>
                    {leaf.sources?.length || 0} source{leaf.sources?.length === 1 ? '' : 's'}
                    {leaf.claims?.length > 0 && <span> · {leaf.claims.length} claim{leaf.claims.length === 1 ? '' : 's'}</span>}
                  </div>
                  {act && (
                    <div class="flex items-center gap-2 shrink-0" title={`${act.count} pass${act.count === 1 ? '' : 'es'} · last touched ${absTime(act.lastTouched)}`}>
                      <svg viewBox="0 0 100 12" class="w-24 h-3" preserveAspectRatio="none" aria-label={`${act.count} passes`}>
                        <line x1="0" y1="11" x2="100" y2="11" stroke="var(--color-line)" stroke-width="0.4" />
                        {act.ticks.map((t) => (
                          <line x1={(t * 100).toFixed(2)} y1="2" x2={(t * 100).toFixed(2)} y2="11" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" />
                        ))}
                      </svg>
                      <span class="font-mono">{relativeTime(act.lastTouched)}</span>
                    </div>
                  )}
                </div>
              )}
            </a>
          </li>);
        })}
      </ul>
    </section>
  )}

  {synthesisNodes.length > 0 && (
    <section class="mb-10">
      <h3 class="text-lg font-serif font-semibold mb-3">Analyses</h3>
      <ul class="space-y-2">
        {synthesisNodes.map((node) => {
          const p = progress(node);
          return (
          <li>
            <a href={`/${slug}/leaves/${node.id}/`} class="block border border-[var(--color-line)] rounded p-3 hover:border-[var(--color-accent)] hover:bg-[var(--color-paper-dim)]/30 transition-colors">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <div class="flex items-baseline gap-2 flex-1 min-w-0">
                  <span class="font-mono text-xs text-[var(--color-ink-soft)] shrink-0">{node.id}</span>
                  <span class="font-medium">{node.question}</span>
                </div>
                <span class:list={[
                  'text-xs px-2 py-0.5 rounded font-mono shrink-0',
                  node.status === 'answered' ? 'bg-[var(--color-leaf)]/15 text-[var(--color-leaf)]'
                  : p.done > 0 ? 'bg-[var(--color-warn)]/15 text-[var(--color-warn)]'
                  : 'bg-[var(--color-paper-dim)] text-[var(--color-ink-soft)]'
                ]}>
                  {node.status === 'answered' ? 'answered' : p.total > 0 ? `${p.done}/${p.total} done` : 'open'}
                </span>
              </div>
              {node.answer && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{node.answer}</p>}
            </a>
          </li>);
        })}
      </ul>
    </section>
  )}

  {constraintNodes.length > 0 && (
    <section class="mb-10">
      <h3 class="text-lg font-serif font-semibold mb-3">Side Chapters</h3>
      <p class="text-xs text-[var(--color-ink-soft)] mb-3">
        Structural or orthogonal deep-dives surfaced during research. Could materially shift the bottom line but live outside the main DAG.
      </p>
      <ul class="space-y-2">
        {constraintNodes.map((node) => {
          const p = progress(node);
          return (
          <li>
            <a href={`/${slug}/leaves/${node.id}/`} class="block border border-[var(--color-line)] rounded p-3 hover:border-[var(--color-accent)] hover:bg-[var(--color-paper-dim)]/30 transition-colors">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <div class="flex items-baseline gap-2 flex-1 min-w-0">
                  <span class="font-mono text-xs text-[var(--color-ink-soft)] shrink-0">{node.id}</span>
                  <span class="font-medium">{node.question}</span>
                </div>
                <span class:list={[
                  'text-xs px-2 py-0.5 rounded font-mono shrink-0',
                  p.done > 0 ? 'bg-[var(--color-warn)]/15 text-[var(--color-warn)]'
                  : 'bg-[var(--color-paper-dim)] text-[var(--color-ink-soft)]'
                ]}>
                  {p.total > 0 ? `${p.done}/${p.total} done` : 'open'}
                </span>
              </div>
              {node.answer && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{node.answer}</p>}
            </a>
          </li>);
        })}
      </ul>
    </section>
  )}
</ReportLayout>
