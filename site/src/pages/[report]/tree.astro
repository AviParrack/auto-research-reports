---
import ReportLayout from '../../layouts/ReportLayout.astro';
import { listReportSlugs, loadReport, getNodeChildren, type TreeNode } from '../../lib/reports';

export function getStaticPaths() {
  return listReportSlugs().map((slug) => ({ params: { report: slug } }));
}

const { report: slug } = Astro.params;
const report = loadReport(slug!);

function nodesByParent(parentId: string): TreeNode[] {
  return getNodeChildren(report.tree, parentId);
}
---
<ReportLayout report={report} title={`Tree — ${report.meta.root_question}`} activeTab="tree">
  <div class="mb-6">
    <h2 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-2">Question DAG</h2>
    <p class="text-sm text-[var(--color-ink-soft)]">
      The decomposition of the root question. Agents propose new nodes during passes; depth+2 expansions require Avi's approval.
    </p>
  </div>

  <div class="bg-[var(--color-paper-dim)] border-l-4 border-[var(--color-accent)] p-4 mb-6 rounded-r">
    <div class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)] mb-1">Root</div>
    <div class="font-serif text-lg font-semibold">{report.tree.root.question}</div>
  </div>

  <ul class="space-y-2">
    {nodesByParent('root').map((node) => (
      <li>
        <a href={`/${slug}/leaves/${node.id}/`} class="block border border-[var(--color-line)] rounded p-3 hover:border-[var(--color-accent)] hover:bg-[var(--color-paper-dim)]/30 transition-colors">
          <div class="flex items-baseline justify-between gap-3 mb-1">
            <div class="flex items-baseline gap-2 flex-1">
              <span class="text-xs font-mono text-[var(--color-ink-soft)]">{node.id}</span>
              <span class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-paper-dim)] text-[var(--color-ink-soft)]">{node.type}</span>
              <span class="font-medium">{node.question}</span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              {node.created_by === 'avi' && (
                <span class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-accent)]/10 text-[var(--color-accent)]">avi</span>
              )}
              <span class:list={[
                'text-xs px-2 py-0.5 rounded font-mono',
                node.status === 'answered' ? 'bg-[var(--color-leaf)]/15 text-[var(--color-leaf)]'
                : node.status === 'researching' ? 'bg-[var(--color-warn)]/15 text-[var(--color-warn)]'
                : 'bg-[var(--color-paper-dim)] text-[var(--color-ink-soft)]'
              ]}>
                {node.status}
              </span>
            </div>
          </div>
          {node.answer && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{node.answer}</p>}
          {node.children && node.children.length > 0 && (
            <ul class="mt-3 ml-4 space-y-1 border-l border-[var(--color-line)] pl-3">
              {nodesByParent(node.id).map((child) => (
                <li class="text-sm">
                  <span class="text-xs font-mono text-[var(--color-ink-soft)] mr-2">{child.id}</span>
                  {child.question}
                </li>
              ))}
            </ul>
          )}
        </a>
      </li>
    ))}
  </ul>
</ReportLayout>
