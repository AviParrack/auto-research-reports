---
import ReportLayout from '../../../layouts/ReportLayout.astro';
import { listReportSlugs, loadReport, renderMath } from '../../../lib/reports';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

export function getStaticPaths() {
  const paths = [];
  const REPORTS_DIR = path.resolve(process.cwd(), '../reports');
  for (const slug of listReportSlugs()) {
    const leavesDir = path.join(REPORTS_DIR, slug, '02-leaves');
    if (!fs.existsSync(leavesDir)) continue;
    const seen = new Set<string>();
    for (const leafName of fs.readdirSync(leavesDir)) {
      const sourcesDir = path.join(leavesDir, leafName, 'sources');
      if (!fs.existsSync(sourcesDir)) continue;
      for (const sName of fs.readdirSync(sourcesDir)) {
        const extractPath = path.join(sourcesDir, sName, 'extract.md');
        if (fs.existsSync(extractPath) && !seen.has(sName)) {
          seen.add(sName);
          paths.push({ params: { report: slug, source: sName } });
        }
      }
    }
  }
  return paths;
}

const { report: slug, source: sourceSlug } = Astro.params;
const report = loadReport(slug!);

const REPORTS_DIR = path.resolve(process.cwd(), '../reports');
let extractBody: string | null = null;
let reviewBody: string | null = null;
let sourceMeta: any = null;
const citedBy: string[] = [];

for (const leaf of report.leaves) {
  const src = leaf.sources.find((s) => s.slug === sourceSlug);
  if (src) {
    citedBy.push(leaf.id);
    if (!extractBody) {
      extractBody = src.body;
      sourceMeta = src;
    }
    const reviewPath = path.join(REPORTS_DIR, slug!, '02-leaves', leaf.id, 'sources', sourceSlug!, 'review.md');
    if (fs.existsSync(reviewPath) && !reviewBody) {
      const parsed = matter(fs.readFileSync(reviewPath, 'utf8'));
      reviewBody = parsed.content;
    }
  }
}
---
<ReportLayout report={report} title={`${sourceMeta?.title || sourceSlug} — Source`} activeTab="sources">
  <div class="text-sm text-[var(--color-ink-soft)] mb-4 flex items-center gap-3">
    <a href={`/${slug}/sources/`} class="hover:text-[var(--color-accent)]">← Sources</a>
    <span class="text-[var(--color-line)]">·</span>
    <a href={`/${slug}/`} class="hover:text-[var(--color-accent)]">Report home</a>
  </div>

  <div class="mb-6">
    <div class="text-xs font-mono text-[var(--color-ink-soft)] mb-1">{sourceSlug}</div>
    <h2 class="text-2xl font-serif font-semibold mb-2">{sourceMeta?.title || sourceSlug}</h2>
    <div class="text-xs text-[var(--color-ink-soft)] flex flex-wrap gap-3 mb-2">
      {sourceMeta?.authors && <span>{sourceMeta.authors.join(', ')}</span>}
      {sourceMeta?.year && <span>{sourceMeta.year}</span>}
      {sourceMeta?.type && <span class="px-1.5 py-0.5 bg-[var(--color-paper-dim)] rounded">{sourceMeta.type}</span>}
      {citedBy.length > 0 && (
        <span>cited by: {citedBy.map((id) => (
          <a href={`/${slug}/leaves/${id}/`} class="font-mono mr-2 hover:text-[var(--color-accent)]">{id}</a>
        ))}</span>
      )}
    </div>
    {sourceMeta?.url && <a href={sourceMeta.url} target="_blank" rel="noopener" class="text-sm text-[var(--color-accent)] hover:underline break-all">{sourceMeta.url}</a>}
  </div>

  {reviewBody && (
    <section class="mb-8">
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Source review</h3>
      <article class="prose-leaf" set:html={renderMath(reviewBody, { inline: false })} />
    </section>
  )}

  {extractBody && (
    <section class="mb-8">
      <h3 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Extract</h3>
      <article class="prose-leaf" set:html={renderMath(extractBody, { inline: false })} />
    </section>
  )}

  {!reviewBody && !extractBody && (
    <div class="border border-[var(--color-line)] rounded p-6 text-[var(--color-ink-soft)]">
      No content captured for this source yet.
    </div>
  )}
</ReportLayout>
