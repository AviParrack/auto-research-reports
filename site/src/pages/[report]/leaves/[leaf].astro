---
import ReportLayout from '../../../layouts/ReportLayout.astro';
import { listReportSlugs, loadReport, getLeafBySlug, renderMath } from '../../../lib/reports';
import { marked } from 'marked';

export function getStaticPaths() {
  const paths = [];
  for (const slug of listReportSlugs()) {
    const report = loadReport(slug);
    for (const node of report.tree.nodes) {
      paths.push({ params: { report: slug, leaf: node.id } });
    }
  }
  return paths;
}

const { report: slug, leaf: leafId } = Astro.params;
const report = loadReport(slug!);
const leaf = getLeafBySlug(report, leafId!);
const node = report.tree.nodes.find((n) => n.id === leafId);
const bodyHtml = leaf?.body ? renderMath(leaf.body, { inline: false }) : null;
---
<ReportLayout report={report} title={node?.question ?? leafId!} activeTab="leaves">
  <a href={`/${slug}/leaves/`} class="text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] mb-4 inline-block">← All leaves</a>

  <div class="mb-6">
    <div class="text-xs font-mono text-[var(--color-ink-soft)] mb-1">{leafId}</div>
    <h2 class="text-2xl font-serif font-semibold mb-2">{node?.question ?? leafId}</h2>
    {node?.answer && (
      <div class="prose-leaf bg-[var(--color-paper-dim)] border-l-4 border-[var(--color-accent)] p-4 rounded-r">
        <p>{node.answer}</p>
        {node.confidence && (
          <div class="text-xs text-[var(--color-ink-soft)] mt-2">
            Confidence: <span class="font-mono">{node.confidence}</span>
          </div>
        )}
      </div>
    )}
  </div>

  {leaf ? (
    <>
      {/* Lead: the leaf report prose */}
      {bodyHtml && (
        <article class="prose-leaf mb-10" set:html={bodyHtml} />
      )}

      {/* Agreement heat map — per-claim evidence-verdict tiles */}
      {leaf.claims.length > 0 && (
        <section class="mb-8 border border-[var(--color-line)] rounded p-4">
          <div class="flex items-baseline justify-between mb-3">
            <div class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">Evidence agreement</div>
            <div class="flex items-center gap-3 text-xs text-[var(--color-ink-soft)]">
              <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm" style="background: var(--color-leaf)"></span>supports</span>
              <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm" style="background: var(--color-warn)"></span>partial</span>
              <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm" style="background: var(--color-flag)"></span>contradicts</span>
              <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded-sm" style="background: var(--color-unaudited)"></span>none</span>
            </div>
          </div>
          <ul class="divide-y divide-[var(--color-line)]">
            {leaf.claims.map((claim) => {
              // Compute supports/partial/contradicts counts
              const counts = { supports: 0, partial: 0, contradicts: 0 };
              for (const ev of claim.evidence || []) {
                const v = ev.verdict || '';
                if (v === 'supports') counts.supports++;
                else if (v === 'partial' || v === 'weak') counts.partial++;
                else if (v === 'contradicts' || v === 'contradicted' || v === 'unsupported') counts.contradicts++;
              }
              const evCount = claim.evidence?.length || 0;
              const tallyTitle = `${counts.supports} supports · ${counts.partial} partial · ${counts.contradicts} contradicts`;
              // Short label = first hyphen-segment of source slug (e.g. metzger-2023 → metzger)
              const shortLabel = (slug: string) => (slug || '').split('-')[0];
              return (
              <li class="grid grid-cols-[3rem_1fr] gap-x-3 gap-y-2 py-2.5 first:pt-0 last:pb-0">
                {/* Row 1: claim id + full text, no truncation */}
                <span class="font-mono text-xs text-[var(--color-ink-soft)] pt-0.5">{claim.id}</span>
                <span class="text-sm">{claim.text}</span>
                {/* Row 2: labeled tile strip aligned under claim text */}
                <div class="col-start-2 flex flex-wrap gap-2" title={tallyTitle}>
                  {evCount === 0 ? (
                    <div class="flex flex-col items-center gap-0.5">
                      <span class="inline-block w-4 h-4 rounded-sm" style="background: var(--color-unaudited); opacity: 0.4"></span>
                      <span class="text-[10px] font-mono text-[var(--color-ink-soft)] leading-none">no ev.</span>
                    </div>
                  ) : (claim.evidence || []).map((ev) => {
                    const v = ev.verdict || '';
                    let bg = 'var(--color-unaudited)';
                    if (v === 'supports') bg = 'var(--color-leaf)';
                    else if (v === 'partial' || v === 'weak') bg = 'var(--color-warn)';
                    else if (v === 'contradicts' || v === 'contradicted' || v === 'unsupported') bg = 'var(--color-flag)';
                    return (
                      <div class="flex flex-col items-center gap-0.5" title={`${ev.source}: ${v}`}>
                        <span class="inline-block w-4 h-4 rounded-sm" style={`background: ${bg}`}></span>
                        <span class="text-[10px] font-mono text-[var(--color-ink-soft)] leading-none">{shortLabel(ev.source)}</span>
                      </div>
                    );
                  })}
                </div>
              </li>);
            })}
          </ul>
        </section>
      )}

      {/* Compact pass status strip */}
      <section class="mb-8 border border-[var(--color-line)] rounded p-3 bg-[var(--color-paper-dim)]/30">
        <div class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)] mb-2">Pass status</div>
        <div class="flex flex-wrap gap-3 text-xs font-mono">
          {Object.entries(leaf.passes_status).map(([k, v]) => (
            <span class:list={[
              v === 'done' ? 'text-[var(--color-leaf)]'
              : v === 'in_progress' ? 'text-[var(--color-warn)]'
              : v === 'needs_rerun' ? 'text-[var(--color-flag)]'
              : 'text-[var(--color-unaudited)]'
            ]}>
              {v === 'done' ? '✓' : v === 'in_progress' ? '◐' : v === 'needs_rerun' ? '↻' : '○'} {k}
            </span>
          ))}
        </div>
      </section>

      {/* Claims — collapsed by default */}
      {leaf.claims.length > 0 && (
        <details class="mb-6 border border-[var(--color-line)] rounded">
          <summary class="cursor-pointer p-3 hover:bg-[var(--color-paper-dim)]/30">
            <span class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)]">Claims</span>
            <span class="ml-2 text-xs text-[var(--color-ink-soft)]">({leaf.claims.length}) · evidence + audit status</span>
          </summary>
          <ul class="space-y-2 p-3 pt-0">
            {leaf.claims.map((claim) => (
              <li class="border border-[var(--color-line)] rounded p-3">
                <div class="flex items-start justify-between gap-3 mb-1">
                  <div class="flex-1">
                    <span class="text-xs font-mono text-[var(--color-ink-soft)] mr-2">{claim.id}</span>
                    <span>{claim.text}</span>
                  </div>
                  <div class="flex items-center gap-1 shrink-0">
                    <span class="text-xs font-mono text-[var(--color-ink-soft)]">{claim.confidence}</span>
                    {claim.audit?.gpt && (
                      <span title={`GPT audit: ${claim.audit.gpt.status}`} class:list={[
                        'text-xs',
                        claim.audit.gpt.status === 'passed' ? 'text-[var(--color-leaf)]'
                        : claim.audit.gpt.status === 'flagged' ? 'text-[var(--color-flag)]'
                        : 'text-[var(--color-unaudited)]'
                      ]}>
                        {claim.audit.gpt.status === 'passed' ? '✓' : claim.audit.gpt.status === 'flagged' ? '⚠' : '○'}
                      </span>
                    )}
                    {claim.audit?.human?.status === 'noted' && <span title="Has human comment" class="text-xs text-[var(--color-accent)]">💬</span>}
                  </div>
                </div>
                {claim.evidence && claim.evidence.length > 0 && (
                  <div class="text-xs text-[var(--color-ink-soft)] mt-2 flex flex-wrap gap-2">
                    {claim.evidence.map((e) => (
                      <span class="font-mono px-2 py-0.5 bg-[var(--color-paper-dim)] rounded">
                        {e.source}
                        {e.verdict === 'contradicts' && <span class="text-[var(--color-flag)]"> ✗</span>}
                        {e.verdict === 'supports' && <span class="text-[var(--color-leaf)]"> ✓</span>}
                      </span>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ul>
        </details>
      )}

      {/* Hidden block for the old pass status section — replaced above */}
      <section class="hidden">
        <h3 class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)] mb-3">Pass Status</h3>
        <ul class="text-sm font-mono space-y-1">
          {Object.entries(leaf.passes_status).map(([k, v]) => (
            <li class="flex items-center gap-2">
              <span class:list={[
                v === 'done' ? 'text-[var(--color-leaf)]'
                : v === 'in_progress' ? 'text-[var(--color-warn)]'
                : v === 'needs_rerun' ? 'text-[var(--color-flag)]'
                : 'text-[var(--color-unaudited)]'
              ]}>
                {v === 'done' ? '✓' : v === 'in_progress' ? '◐' : v === 'needs_rerun' ? '↻' : '○'}
              </span>
              <span>{k}: {v.replace('_', ' ')}</span>
            </li>
          ))}
        </ul>
      </section>

      {leaf.sources && leaf.sources.length > 0 && (
        <details class="mb-6 border border-[var(--color-line)] rounded">
          <summary class="cursor-pointer p-3 hover:bg-[var(--color-paper-dim)]/30">
            <span class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)]">Sources cited</span>
            <span class="ml-2 text-xs text-[var(--color-ink-soft)]">({leaf.sources.length}) · expandable</span>
          </summary>
          <ul class="space-y-3 p-3 pt-0">
            {leaf.sources.map((s) => (
              <li class="border border-[var(--color-line)] rounded p-3">
                <div class="flex items-baseline justify-between gap-3 mb-1">
                  <div>
                    <a href={`/${slug}/sources/${s.slug}/`} class="font-mono text-xs text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] mr-2">{s.slug}</a>
                    {s.title && <span class="font-medium">{s.title}</span>}
                  </div>
                  <div class="text-xs text-[var(--color-ink-soft)] font-mono shrink-0">
                    {s.authors && s.authors.length > 0 && <span class="mr-2">{s.authors.join(', ')}</span>}
                    {s.year && <span>{s.year}</span>}
                    {s.type && <span class="ml-2 px-1.5 py-0.5 bg-[var(--color-paper-dim)] rounded">{s.type}</span>}
                  </div>
                </div>
                {s.url && (
                  <a href={s.url} target="_blank" rel="noopener" class="text-xs text-[var(--color-accent)] hover:underline break-all">{s.url}</a>
                )}
                <details class="mt-2">
                  <summary class="text-xs text-[var(--color-ink-soft)] cursor-pointer hover:text-[var(--color-ink)]">show extract ({Math.round(s.body.length / 100) / 10}k chars)</summary>
                  <article class="prose-leaf mt-3 text-sm" set:html={renderMath(s.body, { inline: false })} />
                </details>
              </li>
            ))}
          </ul>
        </details>
      )}

      {leaf.passArtifacts && leaf.passArtifacts.length > 0 && (
        <details class="mb-6 border border-[var(--color-line)] rounded">
          <summary class="cursor-pointer p-3 hover:bg-[var(--color-paper-dim)]/30">
            <span class="text-sm uppercase tracking-wider text-[var(--color-ink-soft)]">Pass artifacts</span>
            <span class="ml-2 text-xs text-[var(--color-ink-soft)]">({leaf.passArtifacts.length}) · debug trail</span>
          </summary>
          <ul class="space-y-3 p-3 pt-0">
            {leaf.passArtifacts.map((p) => (
              <li class="border border-[var(--color-line)] rounded p-3">
                <details>
                  <summary class="cursor-pointer hover:text-[var(--color-accent)]">
                    <span class="font-mono text-xs text-[var(--color-ink-soft)] mr-2">{p.filename}</span>
                    <span class="text-sm font-medium">{p.kind}</span>
                    {p.kind.endsWith('audit') && <span class="ml-2 text-xs px-1.5 py-0.5 rounded bg-[var(--color-paper-dim)]">codex critique</span>}
                  </summary>
                  <article class="prose-leaf mt-3 text-sm" set:html={renderMath(p.body, { inline: false })} />
                </details>
              </li>
            ))}
          </ul>
        </details>
      )}
    </>
  ) : (
    <div class="border border-[var(--color-line)] rounded p-6 text-[var(--color-ink-soft)]">
      No content yet for this leaf. The leaf pipeline hasn't been run.
      {node?.created_by === 'agent' && (
        <div class="mt-2 text-xs">This node was added by an agent in pass #{node.created_pass}.</div>
      )}
    </div>
  )}
</ReportLayout>
